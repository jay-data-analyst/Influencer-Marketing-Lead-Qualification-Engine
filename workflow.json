    {
      "parameters": {
        "jsCode": "const pollingData = $input.first().json;\n\nconst runStatus = pollingData.status || pollingData.data?.status || \"RUNNING\";\n\nconst storedRunId = $('Store Run ID').first().json.stored_run_id;\nconst storedDatasetId = $('Store Run ID').first().json.stored_dataset_id;\nconst storedLeadName = $('Store Run ID').first().json.stored_lead_name;\nconst storedRowNumber = $('Store Run ID').first().json.stored_row_number;\nconst storedIgHandle = $('Store Run ID').first().json.stored_ig_handle;\nconst storedFollowers = $('Store Run ID').first().json.stored_followers;\n\nreturn [{\n  json: {\n    run_status: runStatus,\n    stored_run_id: storedRunId,\n    stored_dataset_id: storedDatasetId,\n    stored_lead_name: storedLeadName,\n    stored_row_number: storedRowNumber,\n    stored_ig_handle: storedIgHandle,\n    stored_followers: storedFollowers\n  }\n}];"
