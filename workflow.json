      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  const json = item.json;\n\n  const igLink =\n    json.ig_link ||\n    json.ig_handle ||\n    json[\"IG Link\"] ||\n    json[\"Instagram\"] ||\n    json[\"instagram\"] ||\n    json[\"Instagram Link\"] ||\n    json[\"ig link\"] ||\n    \"\";\n\n  let clean = igLink\n    .toString()\n    .trim()\n    .replace(/\\?.*$/, \"\")\n    .replace(/\\/+$/, \"\");\n\n  let handle = \"\";\n\n  if (clean.includes(\"instagram.com\")) {\n    const parts = clean.split(\"/\");\n    handle = parts[parts.length - 1].toLowerCase().trim();\n  } else if (clean.startsWith(\"@\")) {\n    handle = clean.replace(\"@\", \"\").toLowerCase().trim();\n  } else {\n    handle = clean.toLowerCase().trim();\n  }\n\n  handle = handle.replace(\"@\", \"\");\n\n  const invalidHandles = [\"p\", \"reel\", \"stories\", \"explore\", \"accounts\", \"\"];\n\n  const currentStatus = (json.status || \"\")\n    .toString()\n    .trim()\n    .toLowerCase();\n\n  if (currentStatus === \"sql\" || currentStatus === \"not sql\") {\n    output.push({\n      json: {\n        ...json,\n        ig_generated_handle: handle,\n        should_process: false,\n        skip_reason: \"Already processed\"\n      }\n    });\n    continue;\n  }\n\n  if (!handle || invalidHandles.includes(handle)) {\n    output.push({\n      json: {\n        ...json,\n        ig_generated_handle: \"\",\n        should_process: false,\n        skip_reason: \"Invalid Instagram profile link\"\n      }\n    });\n    continue;\n  }\n\n  output.push({\n    json: {\n      ...json,\n      ig_generated_handle: handle,\n      should_process: true,\n      skip_reason: \"\"\n    }\n  });\n}\n\nreturn output;"
      },
