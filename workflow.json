    {
      "parameters": {
        "jsCode": "try {\n  const allItems = $input.all().map(i => i.json);\n\n  const storedData = $('Store Run ID').first().json;\n  const leadName = storedData.stored_lead_name || \"\";\n  const rowNumber = storedData.stored_row_number || \"\";\n  const igHandle = storedData.stored_ig_handle || \"\";\n  const followers = storedData.stored_followers || 0;\n\n  let collabCount = 0;\n  let reelCount = 0;\n\n  // ✅ Caption signals — actual paid partnership language\n  const captionSignals = [\n    \"paid partnership\",\n    \"paid collaboration\",\n    \"gifted by\",\n    \"gifted from\",\n    \"in collaboration with\",\n    \"in association with\",\n    \"sponsored by\",\n    \"partnered with\",\n    \"#ad\",\n    \"#paidpartnership\",\n    \"#paidcollaboration\",\n    \"#sponsored\",\n    \"#gifted\",\n    \"#brandambassador\",\n    \"#collab\",\n    \"#promotion\"\n  ];\n\n  // ✅ Hashtag signals — unambiguous paid marketing tags\n  const signalHashtags = [\n    \"ad\",\n    \"paidpartnership\",\n    \"paidcollaboration\",\n    \"brandambassador\",\n    \"gifted\",\n    \"sponsored\",\n    \"collab\",\n    \"promotion\",\n    \"partner\",\n    \"brandpartner\",\n    \"paid\"\n  ];\n\n  for (const item of allItems) {\n\n    if (!item.caption && !item.hashtags && !item.type) continue;\n\n    const mediaType = (item.type || \"\").toLowerCase();\n    const isReel =\n      mediaType === \"video\" ||\n      mediaType === \"graphvideo\" ||\n      mediaType.includes(\"video\");\n\n    if (!isReel) continue;\n\n    reelCount++;\n\n    const caption = (item.caption || \"\").toLowerCase();\n    const hasCaption = captionSignals.some(s => caption.includes(s));\n\n    const hashtagArray = (item.hashtags || []).map(h => h.toLowerCase());\n    const hasHashtag = hashtagArray.some(h => signalHashtags.includes(h));\n\n    // ✅ Most reliable — Instagram's own paid label\n    const hasPaidPartnership = item.isPaidPartnership === true;\n\n    // ✅ coauthorProducers check\n    let hasCoauthor = false;\n    if (Array.isArray(item.coauthorProducers) && item.coauthorProducers.length > 0) {\n      hasCoauthor = true;\n    }\n    if (!hasCoauthor) {\n      const flatKeys = Object.keys(item);\n      hasCoauthor = flatKeys.some(key => key.startsWith(\"coauthorProducers.\"));\n    }\n\n    // ✅ KEY FIX: coauthorProducers alone is NOT enough\n    // It only counts as a collab when COMBINED with a caption/hashtag signal\n    // OR when isPaidPartnership is true\n    // This filters out colleges/content teams tagging their own sub-accounts\n    const isRealCollab =\n  hasPaidPartnership ||\n  hasCaption ||\n  hasHashtag ||\n  hasCoauthor;  // Instagram Collab post counts on its own\n\n    if (isRealCollab) {\n      collabCount++;\n    }\n  }\n\n  if (reelCount === 0) {\n    return [{\n      json: {\n        lead_name: leadName,\n        row_number: rowNumber,\n        ig_generated_handle: igHandle,\n        status: \"Not SQL\",\n        collab_count: 0,\n        followers: followers,\n        checked_date: new Date().toISOString().split(\"T\")[0],\n        skip_reason: \"No reels found on profile\"\n      }\n    }];\n  }\n\n  return [{\n    json: {\n      lead_name: leadName,\n      row_number: rowNumber,\n      ig_generated_handle: igHandle,\n      status: collabCount >= 3 ? \"SQL\" : \"Not SQL\",\n      collab_count: collabCount,\n      followers: followers,\n      checked_date: new Date().toISOString().split(\"T\")[0],\n      skip_reason: collabCount < 3 ? `Only ${collabCount} collab signals found` : \"\"\n    }\n  }];\n\n} catch (e) {\n  const storedData = $('Store Run ID').first().json;\n  return [{\n    json: {\n      lead_name: storedData.stored_lead_name || \"\",\n      row_number: storedData.stored_row_number || \"\",\n      ig_generated_handle: storedData.stored_ig_handle || \"\",\n      status: \"Not SQL\",\n      collab_count: 0,\n      checked_date: new Date().toISOString().split(\"T\")[0],\n      skip_reason: `Error: ${e.message}`\n    }\n  }];\n}"
      },
